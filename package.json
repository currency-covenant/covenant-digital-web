{
  "name": "covenant-digital-web",
  "version": "0.1.0",
  "private": true,
  "description": "Covenant Digital storefront — Bun, Hono, Vite, React",
  "license": "MIT",
  "packageManager": "bun@1.2.4",
  "scripts": {
    "dev": "turbo dev",
    "dev:client": "turbo dev --filter=client",
    "dev:server": "turbo dev --filter=server",
    "build": "turbo build",
    "build:client": "turbo build --filter=client",
    "build:server": "turbo build --filter=server",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "postinstall": "turbo build --filter=shared --filter=server"
  },
  "workspaces": ["./server", "./client", "./shared"],
  "devDependencies": {
    "bun-types": "latest",
    "turbo": "^2.7.4"
  },
  "peerDependencies": {
    "typescript": "^5.8.3"
  }
}
